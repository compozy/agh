        "start": "next start",
        "test": "vitest run",
        "typecheck": "tsgo --noEmit"
    },
    "dependencies": {
        "@agh/ui": "workspace:*",
        "@orama/orama": "^3.1.18",
        "fumadocs-core": "^16.7.16",

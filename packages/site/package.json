{
    "name": "@agh/site",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "generate:openapi": "bun run scripts/generate-openapi.ts",
        "source:generate": "fumadocs-mdx source.config.ts .source",
        "content:generate": "velite build",
        "predev": "bun run generate:openapi && bun run source:generate && bun run content:generate",
        "prebuild": "bun run generate:openapi && bun run source:generate && bun run content:generate",
        "pretypecheck": "bun run generate:openapi && bun run source:generate && bun run content:generate",
        "pretest": "bun run generate:openapi && bun run source:generate && bun run content:generate",
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "test": "vitest run",
        "typecheck": "tsgo --noEmit"
    },
    "dependencies": {
        "@agh/ui": "workspace:*",
        "@mdx-js/mdx": "^3.1.1",
        "@orama/orama": "^3.1.18",
        "@remotion/player": "^4.0.459",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "fumadocs-core": "^16.8.9",
        "fumadocs-mdx": "^15.0.2",
        "fumadocs-openapi": "^10.8.2",
        "fumadocs-ui": "^16.8.9",
        "lucide-react": "^1.7.0",
        "mermaid": "^11.15.0",
        "next": "^16.2.6",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "reading-time": "^1.5.0",
        "rehype-pretty-code": "^0.14.3",
        "remark": "^15.0.1",
        "remark-gfm": "^4.0.1",
        "remark-mdx": "^3.1.1",
        "remotion": "^4.0.459",
        "shiki": "^4.0.2",
        "velite": "^0.3.1"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^6.0.1",
        "jsdom": "^29.1.1",
        "tailwindcss": "^4.3.0",
        "vitest": "^4.1.6"
    }
}

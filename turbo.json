{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": [
        "cmd/agh-codegen/**",
        "internal/api/contract/**",
        "internal/api/spec/**",
        "internal/codegen/openapits/**",
        "internal/codegen/sdkts/**",
        "internal/extension/contract/**",
        "internal/extension/protocol/**",
        "internal/hooks/**",
        "internal/subprocess/handshake.go",
        "magefile.go",
        "openapi/agh.json",
        "openapi/compozy-daemon.json"
    ],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"],
            "env": ["VITE_AGH_API_URL"]
        },
        "@agh/site#build": {
            "dependsOn": ["^build"],
            "outputs": ["out/**", ".next/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "transit": {
            "dependsOn": ["^transit"],
            "outputs": []
        },
        "typecheck": {
            "dependsOn": ["transit"],
            "outputs": []
        },
        "test": {
            "dependsOn": ["transit"],
            "outputs": []
        }
    }
}

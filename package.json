{
    "private": true,
    "workspaces": [
        "packages/ui",
        "packages/site",
        "web",
        "sdk/typescript",
        "sdk/create-extension",
        "sdk/examples/prompt-enhancer"
    ],
    "scripts": {
        "postinstall": "bash scripts/postinstall.sh",
        "prepare": "husky",
        "codegen": "make codegen",
        "codegen-check": "make codegen-check",
        "dev": "turbo run dev --filter=./web",
        "build": "turbo run build",
        "lint": "bun run format && bunx oxlint",
        "format": "bunx oxfmt",
        "format:check": "bunx oxfmt --check",
        "typecheck": "turbo run typecheck",
        "test": "bunx vitest run",
        "test:e2e:runtime": "make test-e2e-runtime",
        "test:e2e:web": "make test-e2e-web",
        "test:e2e": "make test-e2e",
        "test:e2e:nightly": "make test-e2e-nightly"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/node": "^25.6.0",
        "@typescript/native-preview": "^7.0.0-dev.20260415.1",
        "@vitest/coverage-v8": "^4.1.4",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "openapi-typescript": "^7.13.0",
        "oxfmt": "^0.45.0",
        "oxlint": "^1.60.0",
        "shadcn": "^4.2.0",
        "tailwindcss": "^4.2.2",
        "turbo": "^2.9.6",
        "tw-animate-css": "^1.4.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    },
    "lint-staged": {
        "*.go": "make fmt",
        "*.{js,jsx,ts,tsx}": [
            "oxfmt --no-error-on-unmatched-pattern",
            "oxlint"
        ],
        "*.{css,html,json,jsonc,yaml,yml,md}": [
            "oxfmt --no-error-on-unmatched-pattern"
        ]
    },
    "packageManager": "bun@1.3.4"
}

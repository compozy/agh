{
    "private": true,
    "workspaces": [
        "web"
    ],
    "scripts": {
        "prepare": "husky",
        "dev": "turbo run dev --filter=./web",
        "build": "turbo run build",
        "lint": "bun run format && bunx oxlint",
        "format": "bunx oxfmt",
        "format:check": "bunx oxfmt --check",
        "typecheck": "turbo run typecheck",
        "test": "bunx vitest run"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/node": "^25.5.2",
        "@typescript/native-preview": "^7.0.0-dev.20260403.1",
        "@vitest/coverage-v8": "^4.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "oxfmt": "^0.43.0",
        "oxlint": "^1.57.0",
        "shadcn": "^4.1.0",
        "tailwindcss": "^4.2.2",
        "turbo": "^2.8.20",
        "tw-animate-css": "^1.4.0",
        "vite": "^8.0.3",
        "vitest": "^4.1.0"
    },
    "lint-staged": {
        "*.go": "make fmt",
        "*.{js,jsx,ts,tsx}": [
            "oxfmt --no-error-on-unmatched-pattern",
            "oxlint"
        ],
        "*.{css,html,json,jsonc,yaml,yml,md}": [
            "oxfmt --no-error-on-unmatched-pattern"
        ]
    },
    "packageManager": "bun@1.3.4"
}

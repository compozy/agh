{
    "name": "agh-web",
    "private": true,
    "type": "module",
    "scripts": {
        "codegen": "bun run --cwd .. codegen",
        "codegen-check": "bun run --cwd .. codegen-check",
        "dev": "bun run codegen && bun run dev:raw",
        "dev:raw": "vite --port 3000",
        "build": "bun run build:raw",
        "build:raw": "vite build && tsgo --noEmit",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "preview": "vite preview",
        "test": "bun run test:raw",
        "test:raw": "vitest run",
        "test:e2e": "bun run test:e2e:daemon-served",
        "test:e2e:raw": "bun run test:e2e:daemon-served:raw",
        "test:e2e:daemon-served": "bun run codegen-check && bun run test:e2e:daemon-served:raw",
        "test:e2e:daemon-served:raw": "playwright test --grep-invert @nightly",
        "test:e2e:nightly": "bun run codegen-check && bun run test:e2e:nightly:raw",
        "test:e2e:nightly:check": "bun run e2e/scripts/check-nightly-coverage.ts",
        "test:e2e:nightly:raw": "bun run test:e2e:nightly:check && playwright test --grep @nightly",
        "test:e2e:install": "playwright install chromium",
        "lint": "bun run format && bunx oxlint",
        "format": "bunx oxfmt",
        "format:check": "bunx oxfmt --check",
        "typecheck": "bun run typecheck:raw",
        "typecheck:raw": "tsgo --noEmit"
    },
    "dependencies": {
        "@agh/ui": "workspace:*",
        "@ai-sdk/react": "^3.0.179",
        "@assistant-ui/react": "^0.14.0",
        "@assistant-ui/react-ai-sdk": "^1.3.23",
        "@base-ui/react": "^1.4.1",
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource-variable/jetbrains-mono": "^5.2.8",
        "@headless-tree/core": "1.6.3",
        "@headless-tree/react": "1.6.3",
        "@tailwindcss/vite": "^4.3.0",
        "@tanstack/react-query": "^5.100.10",
        "@tanstack/react-router": "^1.169.2",
        "@tanstack/react-virtual": "^3.13.24",
        "ai": "^6.0.177",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "lucide-react": "^1.14.0",
        "motion": "^12.38.0",
        "openapi-fetch": "^0.17.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.4.3",
        "zustand": "^5.0.13"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@storybook/addon-a11y": "^10.3.6",
        "@storybook/addon-docs": "^10.3.6",
        "@storybook/addon-themes": "^10.3.6",
        "@storybook/react-vite": "^10.3.6",
        "@tanstack/devtools-vite": "^0.6.0",
        "@tanstack/react-query-devtools": "^5.100.10",
        "@tanstack/react-router-devtools": "^1.166.13",
        "@tanstack/router-plugin": "^1.167.35",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^6.0.0",
        "jsdom": "^29.1.1",
        "msw": "^2.14.6",
        "msw-storybook-addon": "^2",
        "prop-types": "^15.8.1",
        "storybook": "^10.3.6",
        "vite": "^8.0.12",
        "vitest": "^4.1.6"
    }
}

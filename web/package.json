{
    "name": "agh-web",
    "private": true,
    "type": "module",
    "scripts": {
        "codegen": "bun run --cwd .. codegen",
        "codegen-check": "bun run --cwd .. codegen-check",
        "dev": "bun run codegen && bun run dev:raw",
        "dev:raw": "vite --port 3000",
        "build": "bun run codegen-check && bun run build:raw",
        "build:raw": "vite build && tsgo --noEmit",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "preview": "vite preview",
        "test": "bun run codegen-check && bun run test:raw",
        "test:raw": "vitest run",
        "lint": "bun run format && bunx oxlint",
        "format": "bunx oxfmt",
        "format:check": "bunx oxfmt --check",
        "typecheck": "bun run codegen-check && bun run typecheck:raw",
        "typecheck:raw": "tsgo --noEmit"
    },
    "dependencies": {
        "@agh/ui": "workspace:*",
        "@ai-sdk/react": "^3.0.164",
        "@base-ui/react": "^1.4.0",
        "@fontsource-variable/inter": "^5.2.8",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@tailwindcss/vite": "^4.2.1",
        "@tanstack/react-query": "^5.99.0",
        "@tanstack/react-router": "^1.168.22",
        "@tanstack/react-virtual": "^3.13.23",
        "@types/react-syntax-highlighter": "^15.5.13",
        "ai": "^6.0.162",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "lucide-react": "^1.8.0",
        "next-themes": "^0.4.6",
        "openapi-fetch": "^0.17.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-markdown": "^10.1.0",
        "react-syntax-highlighter": "^16.1.1",
        "remark-gfm": "^4.0.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.0",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@storybook/addon-a11y": "^10.3.5",
        "@storybook/addon-docs": "^10.3.5",
        "@storybook/addon-themes": "^10.3.5",
        "@storybook/react-vite": "^10.3.5",
        "@tanstack/devtools-vite": "^0.6.0",
        "@tanstack/react-query-devtools": "^5.99.0",
        "@tanstack/react-router-devtools": "^1.166.13",
        "@tanstack/router-plugin": "^1.167.22",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^6.0.0",
        "jsdom": "^29.0.2",
        "prop-types": "^15.8.1",
        "storybook": "^10.3.5",
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    }
}

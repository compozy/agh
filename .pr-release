release_artifacts:
  - name: sync-web-assets-module
    command: go
    args:
      - run
      - github.com/magefile/mage@v1.17.0
      - releaseWebAssetsSync
    add:
      - go.mod
      - go.sum
    timeout_seconds: 900
  - name: site-changelog
    command: bun
    args:
      - run
      - release:site-changelog
    add:
      - packages/site/content/blog/changelog/*.mdx
    timeout_seconds: 120
  - name: format-release-artifacts
    command: bun
    args:
      - x
      - oxfmt
      - CHANGELOG.md
      - RELEASE_BODY.md
      - RELEASE_NOTES.md
      - package.json
      - packages/site/content/blog/changelog/*.mdx
    add:
      - CHANGELOG.md
      - RELEASE_BODY.md
      - RELEASE_NOTES.md
      - package.json
      - packages/site/content/blog/changelog/*.mdx
    timeout_seconds: 120

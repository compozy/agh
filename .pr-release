release_artifacts:
  - name: site-changelog
    command: bun
    args:
      - run
      - release:site-changelog
    add:
      - packages/site/content/blog/changelog/*.mdx
    timeout_seconds: 120
  - name: format-release-artifacts
    command: bun
    args:
      - x
      - oxfmt
      - CHANGELOG.md
      - RELEASE_BODY.md
      - RELEASE_NOTES.md
      - package.json
      - packages/site/content/blog/changelog/*.mdx
    add:
      - CHANGELOG.md
      - RELEASE_BODY.md
      - RELEASE_NOTES.md
      - package.json
      - packages/site/content/blog/changelog/*.mdx
    timeout_seconds: 120

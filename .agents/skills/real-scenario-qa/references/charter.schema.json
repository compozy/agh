{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AGH Behavioral Scenario Charter",
  "description": "Charter consumed by the auditor. When the scenario is playbook-driven (real-scenario-qa with --playbook), the bootstrap materializes this charter from the playbook spec — so playbook_ref, required_deliverables, and required_collaboration are populated automatically.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "startup_situation",
    "operator_intent",
    "expected_business_outcome",
    "agents",
    "channels",
    "task_tree",
    "provider_plan",
    "cross_surface_targets",
    "disruption_probes",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "startup_situation": {
      "type": "string",
      "minLength": 1
    },
    "operator_intent": {
      "type": "string",
      "minLength": 1
    },
    "expected_business_outcome": {
      "type": "string",
      "minLength": 1
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "responsibility"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "responsibility": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "channels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "purpose"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "task_tree": {
      "type": "object",
      "required": ["roots", "subtasks", "dependencies", "runs"]
    },
    "provider_plan": {
      "type": "object",
      "required": ["required", "providers", "reachability_probe"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "providers": {
          "type": "array"
        },
        "reachability_probe": {
          "type": "string"
        },
        "fallback_boundary": {
          "type": ["string", "null"]
        }
      }
    },
    "cross_surface_targets": {
      "type": "array"
    },
    "disruption_probes": {
      "type": "array"
    },
    "artifacts": {
      "type": "array"
    },
    "playbook_ref": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "When the charter was materialized from a playbook, this is the playbook ref (e.g., northstar-pay)."
    },
    "required_deliverables": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 },
      "description": "Map of deliverable_type → minimum count of valid (parses/compiles/runs) artifacts the auditor must find."
    },
    "required_collaboration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "peer_messages_min": { "type": "integer", "minimum": 1 },
        "review_cycles_min": { "type": "integer", "minimum": 1 },
        "disagreements_resolved_min": { "type": "integer", "minimum": 0 },
        "channels_active_min": { "type": "integer", "minimum": 1 }
      }
    },
    "kickoff_brief": {
      "type": "string",
      "description": "Single in-persona operator message posted at scenario start. Must not contain any forbidden prompt phrase."
    }
  }
}

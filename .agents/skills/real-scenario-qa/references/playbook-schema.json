{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AGH Real-Scenario QA Playbook",
  "description": "Self-contained startup playbook consumed by real-scenario-qa. The bootstrap helper materializes workspaces, knowledge files, agents, and an open task tree from this spec; the operator kickoff is the only QA-controlled prompt. Auditor reads required_deliverables and required_collaboration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "playbook_ref",
    "company",
    "operator_persona",
    "kickoff_brief",
    "workspaces",
    "agents",
    "channels",
    "knowledge_files",
    "open_tasks",
    "required_deliverables",
    "required_collaboration"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "playbook_ref": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Lowercase kebab-case identifier matching the playbook filename (without .md)."
    },
    "company": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "tagline", "stage"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "short_name": { "type": "string" },
        "tagline": { "type": "string", "minLength": 1 },
        "stage": { "type": "string", "minLength": 1 },
        "industry": { "type": "string" },
        "registry_base_url": { "type": "string" }
      }
    },
    "operator_persona": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "voice_guidelines"],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1,
          "description": "In-persona role for the operator-as-QA, e.g. Founder/PM. Must NOT contain QA, tester, or auditor wording."
        },
        "name": { "type": "string" },
        "voice_guidelines": { "type": "string", "minLength": 1 }
      }
    },
    "kickoff_brief": {
      "type": "string",
      "minLength": 80,
      "description": "Single in-persona message the operator sends at scenario start. Must be a real product directive, not a QA framing."
    },
    "workspaces": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "purpose"],
        "properties": {
          "id": { "type": "string", "pattern": "^ws_[a-z0-9_]+$" },
          "name": { "type": "string", "minLength": 1 },
          "purpose": { "type": "string", "minLength": 1 },
          "knowledge_files": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "persona", "system_prompt", "workspace"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "role": { "type": "string", "minLength": 1 },
          "persona": { "type": "string", "minLength": 1 },
          "system_prompt": {
            "type": "string",
            "minLength": 60,
            "description": "Per-agent system prompt. Must NOT mention QA, evaluation, test, or audit framing."
          },
          "workspace": { "type": "string", "pattern": "^ws_[a-z0-9_]+$" },
          "skills": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "channels": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "purpose"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "purpose": { "type": "string", "minLength": 1 },
          "primary_workspace": { "type": "string", "pattern": "^ws_[a-z0-9_]+$" }
        }
      }
    },
    "knowledge_files": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "content"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "Relative path under WORKSPACE_PATH/knowledge/."
          },
          "content": { "type": "string", "minLength": 1 }
        }
      }
    },
    "open_tasks": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "owner_agent", "deliverable_type"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "owner_agent": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "deliverable_type": {
            "type": "string",
            "enum": [
              "tsx_page",
              "tsx_component",
              "ts_module",
              "ts_test",
              "go_service_stub",
              "go_test",
              "python_script",
              "shell_script",
              "sql_migration",
              "runbook_md",
              "spec_md",
              "config_toml",
              "html_static",
              "yaml_workflow"
            ]
          },
          "deliverable_path_hint": { "type": "string" },
          "review_required_by": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "channel": { "type": "string", "pattern": "^[a-z0-9-]+$" }
        }
      }
    },
    "required_deliverables": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 },
      "description": "Map of deliverable_type → minimum count of valid files (parses/compiles/runs) the auditor must find at scenario end. Total of non-md types must be >= 4."
    },
    "required_collaboration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["peer_messages_min", "review_cycles_min", "disagreements_resolved_min"],
      "properties": {
        "peer_messages_min": { "type": "integer", "minimum": 1 },
        "review_cycles_min": { "type": "integer", "minimum": 1 },
        "disagreements_resolved_min": { "type": "integer", "minimum": 0 },
        "channels_active_min": { "type": "integer", "minimum": 1 }
      }
    },
    "disruption_probe_seeds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "seed_at_minute", "expected_recovery"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "seed_at_minute": { "type": "integer", "minimum": 0 },
          "delivery": {
            "type": "string",
            "enum": ["knowledge_file", "channel_message", "task_event", "config_change"],
            "description": "How the disruption is introduced into the runtime state. Never as a direct prompt to an agent."
          },
          "expected_recovery": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}

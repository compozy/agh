export SCENARIO_SLUG="${SCENARIO_SLUG:-tools-refac-real-scenario}"
export WORKSPACE_PATH="${WORKSPACE_PATH:-${HOME}/dev/qa-labs/agh-${SCENARIO_SLUG}-lab}"
export QA_OUTPUT_PATH="${QA_OUTPUT_PATH:-${WORKSPACE_PATH}/qa-artifacts}"
export AGH_HOME="${AGH_HOME:-${TMPDIR:-/tmp}/aghqa/${SCENARIO_SLUG}/runtime}"
export AGH_HTTP_PORT="${AGH_HTTP_PORT:-57781}"
export AGH_UDS_PATH="${AGH_UDS_PATH:-${AGH_HOME}/aghd.sock}"
export TMUX_BRIDGE_SOCKET="${TMUX_BRIDGE_SOCKET:-${AGH_HOME}/tmux-bridge.sock}"
export AGH_WEB_API_PROXY_TARGET="${AGH_WEB_API_PROXY_TARGET:-http://127.0.0.1:${AGH_HTTP_PORT}}"
export PROVIDER_HOME="${PROVIDER_HOME:-${TMPDIR:-/tmp}/aghqa/${SCENARIO_SLUG}/provider}"
export PROVIDER_CODEX_HOME="${PROVIDER_CODEX_HOME:-${PROVIDER_HOME}/.codex}"
export BROWSER_MODE=browser-use
export BROWSER_BLOCKER=''

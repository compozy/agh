{
    "name": "@agh/extension-sdk",
    "version": "0.1.0",
    "description": "TypeScript SDK for building AGH subprocess extensions",
    "license": "UNLICENSED",
    "files": [
        "dist/**/*"
    ],
    "sideEffects": false,
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "require": "./dist/cjs/index.js",
            "import": "./dist/esm/index.js"
        },
        "./testing": {
            "types": "./dist/types/testing/index.d.ts",
            "require": "./dist/cjs/testing/index.js",
            "import": "./dist/esm/testing/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "rm -rf dist && tsc -p tsconfig.types.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && node ./scripts/postbuild.mjs",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run --config vitest.config.ts",
        "coverage": "vitest run --config vitest.config.ts --coverage"
    },
    "engines": {
        "node": ">=18"
    }
}
